# ----------------------------------------------------------------------------
# Editors / IDEs — local-only, never commit
# ----------------------------------------------------------------------------
.idea/                       # JetBrains
.vscode/                     # VS Code (uncomment if your team commits a shared .vscode/)
.fleet/                      # JetBrains Fleet
.zed/                        # Zed
*.iml                        # JetBrains module files
*.swp                        # vim swap
*.swo                        # vim swap
*~                           # vim backup
\#*\#                        # Emacs autosave
.\#*                         # Emacs lock files
.netrwhist                   # vim netrw history

# ----------------------------------------------------------------------------
# AI tooling — user/session-specific, never commit
# ----------------------------------------------------------------------------
.claude/                     # Claude Code session state
.cursor/                     # Cursor IDE
.cursorignore                # Cursor ignore rules (local pref)
.cursorindexingignore
.aider*                      # Aider AI
.continue/                   # Continue.dev
.copilot/                    # GitHub Copilot local config
.github/copilot-instructions.md   # if it's user-specific

# ----------------------------------------------------------------------------
