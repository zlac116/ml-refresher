# Copy to .env and fill in.
# .env is gitignored at the repo root.

# Anthropic API key — required for the LangGraph supervisor + workers
# Get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# URL of the running LMM surrogate API (capstone 04 api_extension)
# Start it in another terminal:
#   cd ../api_extension && uv run uvicorn app.main:app --reload --port 8003
SURROGATE_API_URL=http://localhost:8003

# Which Claude model to use for the agents
# Default favours the latest cost-efficient tier; bump to Sonnet for harder workflows.
AGENT_MODEL=claude-haiku-4-5-20251001

# Optional — LangSmith tracing (stretch goal ST3)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=lmm-agents-extension
