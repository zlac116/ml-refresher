# Copy to .env and fill in. NEVER commit the real .env.
# Loaded by app/core/config.py via pydantic-settings.

# --- security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256

# --- database (async driver!) ---
# Local/compose Postgres. Note the +asyncpg driver.
DATABASE_URL=postgresql+asyncpg://ledger:ledger@localhost:5432/ledger

# --- app ---
ENV=development            # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- rate limits (requests/window) ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute

# --- observability (optional; leave blank to disable export) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
